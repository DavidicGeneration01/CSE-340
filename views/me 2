#inv-display {
  width: 100%;
  max-width: 700px;
  margin: 2rem auto;
  padding: 0;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 25px;
  justify-content: center;
}

#inv-display li {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  width: 100%;
  max-width: 350px;
  margin: 0 auto;
  background: #fff;
  border: 1px solid #dcdcdc;
  border-radius: 12px;
  box-shadow: 0px 5px 15px rgba(0,0,0,0.12);
  overflow: hidden;
  padding-bottom: 1rem;
}

#inv-display img {
  width: 100%;
  max-width: 350px;
  height: auto;
  display: block;
  margin: 0 auto;
}

.namePrice {
  width: 100%;
  padding: 1rem;
  text-align: center;
}

.namePrice hr {
  width: 80%;
  margin: 0.5rem auto;
  border: none;
  height: 1px;
  background: #ccc;
}

.namePrice h2 {
  margin: 0.5rem 0;
  font-size: 1.4rem;
}

.namePrice h2 a {
  color: #000;
  text-decoration: none;
}

.namePrice h2 a:hover {
  color: #e63946;
}

.namePrice span {
  font-size: 1.1rem;
  font-weight: bold;
  color: #444;
}





/* styling for vehicle details view  */
.detail-header {
	padding-left: 20px;
	margin-top: 20px;
	font-size: 1.5rem;
}

.detailsView {
	display: flex;
	flex-direction: column;
	gap: 20px;
	padding: 20px;
}

.col1 img {
	width: 100%;
	height: 100%;
	object-fit: contain;
}

.col2 li {
	line-height: 1.5;
	padding: 5px;
	border-radius: 4px;
}

.col2 li:nth-of-type(even) {
	background-color: #8eca8e;
}

/* Styling for vehicle management page  */
.mag-title {
	font-size: 1.5rem;
	margin-left: 20px;
	padding: 20px 0;
}

.mag-links {
	border-radius: 6px;
	padding: 20px;
	margin: 0 20px;
	background-color: #023047;
}

.mag-links a {
	color: white;
	text-decoration: underline 1px white;
}




/* ========================= */
/* RESPONSIVE STYLES (KEEP LAYOUT SAME, JUST SCALE) */
/* ========================= */

@media (max-width: 1024px) {
  body {
    font-size: 0.95rem;
  }

  .nav-bar {
    padding: 0.5rem 1rem;
  }

  .hero-image img {
    width: 80%;
    height: auto;
  }

  .dmc-con {
    left: 18%;
    top: 45%;
    padding: 1.5rem;
    max-width: 180px;
  }

  .dmc-con p {
    font-size: 1.5rem;
  }

  .dmc-con img {
    width: 90%;
  }

  /* Keep 2x2 layout for upgrade items but allow scaling */
  .upg-items {
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .fig-items div {
    width: 140px;
    height: 140px;
  }
}

/* Smaller screens (phones and small tablets) */
@media (max-width: 768px) {
  body {
    font-size: 0.9rem;
    background-attachment: scroll; /* Prevents mobile jumpiness */
  }

  .content-wrapper {
    padding: 1rem;
    margin: 1rem;
  }

  /* Keep navigation same, just smaller text */
  #main-header {
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .siteName a {
    font-size: 1.5rem;
  }

  #tools a {
    font-size: 0.9rem;
  }

  .nav-links li a {
    font-size: 0.9rem;
    padding: 0.3rem;
  }

  .hero-image {
    flex-direction: column;
    gap: 1rem;
  }

  .dmc-con {
    width: 50%;
    max-width: 140px;
    left: 5%;
  }

  #up-reviews .reviews {
    order: 1;
  }

  #up-reviews .upgrades {
    order: 2;
  }

  .upg-items {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .siteName a {
    font-size: 1.3rem;
  }

  #tools a {
    font-size: 0.85rem;
  }

  .nav-links li a {
    font-size: 0.85rem;
  }

  .hero-image img {
    width: 100%;
  }

  .dmc-con p {
    font-size: 1.1rem;
  }

  .dmc-con img {
    width: 80%;
  }



  .fig-items div {
    width: 100px;
    height: 100px;
  }
}















