body {
  /* Full-page background image */
  background-image: url("/images/site/small_check.jpg"); /* change path as needed */
  background-size: cover;            /* Make it cover the whole viewport */
  background-repeat: no-repeat;
  background-attachment: fixed;      /* Keep background still while scrolling */
  background-position: center center;
  
  margin: 0;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  color: #222;
}

/* Content wrapper: white background, rounded corners, shadow */
.content-wrapper {
  background-color: #ffffff;
  border: 2px solid #ccc;
  border-radius: 20px;
  padding: 2rem;
  max-width: 1000px;
  margin: 2rem auto;
  box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}


/* Header and navigation inside content */
.content-wrapper header,
.content-wrapper nav {
  margin-bottom: 2rem; /* spacing below header/nav */
}

/* Optional: Hero, reviews, and upgrades spacing */
#hero-section,
#up-reviews {
  margin-bottom: 2rem;
}

/* ===== Header Styling ===== */
#main-header {
  display: flex;                 
  justify-content: space-between;
  align-items: center;           
  padding: 1rem 2rem;            
  background-color: #ffffff;     
}

/* Left side - site name */
.siteName a {
  font-size: 1.8rem;
  font-weight: 600;
  text-decoration: none;
  color: #000; /* black text */
}

/* Right side - account link */
#tools a {
  font-size: 1rem;
  font-weight: 500;
  text-decoration: none;
  color: #000; /* black text */
  transition: color 0.3s ease;
}


#tools a:hover {
  color: #555; /* softer black on hover */
  text-decoration: underline;
}

/* ===== Navigation Bar ===== */
nav {
  background-color: #000000; /* black background */
  padding: 0.75rem 2rem;    /* spacing on left and right */
}

/* The list container */
nav ul {
  list-style: none;
  display: flex;
  justify-content: space-evenly; /* equal space between links */
  align-items: center;
  margin: 0;
  padding: 0;
}

/* Each navigation link */
nav a {
  text-decoration: none;
  color: #ffffff; /* white text for contrast */
  font-family: 'Poppins', sans-serif;
  font-weight: 500;
  font-size: 1rem;
  letter-spacing: 0.6px;
  transition: color 0.3s ease, transform 0.2s ease;
}

/* Hover effect */
nav li a:hover {
  color: #ffcc00; /* gold/yellow accent on hover */
  transform: scale(1.05);
}

h1{
  font-family: 'Poppins', sans-serif;
  color: #111;
  margin-bottom: 3em;
}

/* Hero image container - keep your current layout */
.hero-image {
  position: relative;
  width: 100%;
  height: auto;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;   
}

.hero-image img {
  width: 70%;
  height: auto;
  display: block;
}

/* DMC content box */
.dmc-con {
  position: absolute; /* Layer on top of hero image */
  z-index: 10;        /* Higher than hero image */
  left: 22%;           /* Position on the left side */
  top: 45%;           /* Vertical center */
  transform: translateY(0); /* Perfect vertical centering */
  background-color: rgba(255, 255, 255, 0.8); /* Optional for readability */
  padding: 2rem 2rem;
  border-radius: 12px;
  max-width: 200px;   /* Adjust width */

}

/* Paragraph styling inside DMC content */
.dmc-con p {
  margin: 0 0 1rem 0;
  font-size: 1.8rem;
  color: rgb(25, 168, 220);
  line-height: 1.5;
  text-align: left; /* Ensures content is left-aligned */
}

/* Image inside DMC content */
.dmc-con img {
  width: 95%; /* Fit "Own Today" image inside the box */
  height: auto;
  display: block;
}

#up-reviews {
  display: flex;           /* ensures children are side by side */
  gap: 1rem;               /* space between sections */
  align-items: flex-start; /* align top edges */
  flex-wrap: wrap;         /* wrap on smaller screens */
}


/* Assign order to swap sections */
#up-reviews .upgrades {
  order: 1; /* appear first (left) */
  flex: 2 1 500px; /* wider */
}

#up-reviews .reviews {
  order: 2; /* appear second (right) */
  flex: 1 1 400px; /* smaller */
}

.reviews h2 {
  margin-bottom: 1rem;
  font-family: 'Poppins', 'Raleway', sans-serif;
}

/* Remove default ul styles */
.reviews ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem; /* space between items */
}

/* Each review styled as a card */
.reviews ul li {
    padding: 1rem;
    border-radius: 8px;
    line-height: 1.6; /* spacing between lines */
    word-wrap: break-word; /* wrap long text */
    font-family: 'Poppins', 'Raleway', sans-serif;
    color: rgb(0, 0, 0); /* make text readable on blue */
}

/* Each figure as a grid with image above caption */
.fig-items div {
	width: 150px;
	height: 150px;
	background-color: rgb(18, 165, 223);
	text-align: center;
	display: flex;
	align-items: center;
	justify-content: center;
	box-sizing: border-box;
}

.upg-items {
    display: grid;
    grid-template-columns: repeat(2, 1fr); 
    gap: 0.5rem; /* space between grid items */
    justify-items: center; /* centers each figure inside its grid cell */
}

figcaption {
	text-align: center;
	padding-top: 5px;
}

figcaption a {
	text-decoration: underline 1px var(--rich-black);
	color: var(--rich-black);
	font-family: 'Poppins', 'Raleway', sans-serif;

}

footer {
	margin-top: 20px;
	padding: 10px 0;
	font-weight: 600;
}



